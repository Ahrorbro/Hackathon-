# Wait App — copy to .env and fill with real values. Do not commit .env.
# See docs/Wait-App-API-And-Keys-Needed.md for where to get each value.

# Supabase (you will share)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox (free — for map view). Get at https://account.mapbox.com/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-public-token

# Optional later: Google Places (venue search/details)
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
